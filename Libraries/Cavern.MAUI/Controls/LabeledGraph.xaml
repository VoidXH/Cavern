<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Cavern.MAUI.Controls.LabeledGraph">
    <HorizontalStackLayout HorizontalOptions="Center">
        <Grid RowDefinitions="*,*" ColumnDefinitions="*,*">
            <FlexLayout Direction="Column" x:Name="yAxis" AlignItems="Stretch" JustifyContent="SpaceBetween"/>
            <Image Grid.Column="1" x:Name="image" Margin="10"/>
            <FlexLayout Direction="Row" Grid.Row="1" Grid.Column="1" x:Name="xAxis" AlignItems="Stretch" JustifyContent="SpaceBetween"/>
        </Grid>
    </HorizontalStackLayout>
</ContentView>
