<UserControl x:Class="Cavern.WPF.Controls.LabeledSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Cavern.WPF.Controls"
             mc:Ignorable="d" d:DesignWidth="300" Height="39">
    <Grid>
        <TextBlock Name="label" HorizontalAlignment="Left" VerticalAlignment="Top" Text="Value:"/>
        <TextBlock Name="value" HorizontalAlignment="Right" VerticalAlignment="Top" Text="0.5"/>
        <Slider Name="slider" Margin="0,21,0,0" VerticalAlignment="Top" Minimum="0" Value="0.5" Maximum="1" ValueChanged="SliderChanged"/>
    </Grid>
</UserControl>
