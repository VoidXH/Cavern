<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="CavernAmp" />
		<Option pch_mode="2" />
		<Option compiler="gcc-mingw64" />
		<Option virtualFolders="Cavern/Filters/;Cavern/;Cavern/Utilities/;Cavern.QuickEQ/Utilities/;Cavern.QuickEQ/Equalization/;Cavern.QuickEQ/" />
		<Build>
			<Target title="Release">
				<Option output="bin/Release/CavernAmp" prefix_auto="1" extension_auto="1" />
