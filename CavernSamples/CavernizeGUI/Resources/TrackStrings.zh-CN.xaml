<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <!-- Track info -->
    <system:String x:Key="NoSup">Cavern不支持的格式</system:String>
    <system:String x:Key="E3JOC">Enhanced AC-3（联合对象编码）</system:String>
    <system:String x:Key="ObTra">基于对象的音轨</system:String>
    <system:String x:Key="ChTra">基于声道的音轨</system:String>
    <system:String x:Key="SouCh">源声道</system:String>
    <system:String x:Key="MatBe">矩阵基础层</system:String>
    <system:String x:Key="MatOb">矩阵对象</system:String>
    <system:String x:Key="SouBe">基础声道</system:String>
    <system:String x:Key="SouDy">动态对象</system:String>
    <system:String x:Key="Chans">声道</system:String>
    <system:String x:Key="WiObj">含对象</system:String>

    <!-- Invalid track -->
    <system:String x:Key="InvTr">此音轨无法解码。解码时发生以下错误：</system:String>
    <system:String x:Key="Later">此问题可能会在后续版本中修复。请尝试更新Cavernize，
        如果最新版本中问题仍然存在，请联系开发者 www.sbence.hu。</system:String>

    <!-- Translatable codec names -->
    <system:String x:Key="PCM_Float">PCM（浮点）</system:String>
    <system:String x:Key="PCM_LE">PCM（整数）</system:String>

    <!-- Export formats -->
    <system:String x:Key="C_AC3">AC-3（中档，支持SPDIF）</system:String>
    <system:String x:Key="CEAC3">Enhanced AC-3（中档，支持HDMI ARC）</system:String>
    <system:String x:Key="COpus">Opus（透明，体积小）</system:String>
    <system:String x:Key="CFLAC">FLAC（无损，体积大）</system:String>
    <system:String x:Key="CPCMI">PCM整数（无损，体积较大）</system:String>
    <system:String x:Key="CPCMF">PCM浮点（不必要，体积最大）</system:String>
    <system:String x:Key="CADMC">ADM Broadcast Wave Format（紧凑）</system:String>
    <system:String x:Key="CADMA">ADM Broadcast Wave Format（Dolby Atmos）</system:String>
    <system:String x:Key="CDAMF">Dolby Atmos Master Format</system:String>
    <system:String x:Key="C_LAF">Limitless Audio Format</system:String>
</ResourceDictionary>
