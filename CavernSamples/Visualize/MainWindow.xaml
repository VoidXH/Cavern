<Window x:Class="Visualize.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Visualize"
        Title="Cavern Debug Visualizer" Width="800" Height="450">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <ComboBox Name="waveform" Margin="5" HorizontalAlignment="Left" Width="300" SelectionChanged="OnWaveformChanged"/>
        <Button Margin="5" HorizontalAlignment="Right" Width="100" Content="Load file" Click="LoadFile"/>
        <Grid Name="imageHolder" Grid.Row="1" MouseWheel="OnScroll" SizeChanged="OnResize">
            <Image Name="image" Stretch="Fill"/>
        </Grid>
        <CheckBox Name="normalize" Margin="310,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                  Content="Normalize" IsChecked="True" Click="Redraw"/>
        <TextBlock Name="samples" Grid.Row="2" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center" Text="0 samples"/>
    </Grid>
</Window>
