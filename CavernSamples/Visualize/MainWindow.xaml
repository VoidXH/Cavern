<Window x:Class="Visualize.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Visualize"
        Title="MainWindow" Width="800" Height="450">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ComboBox Name="waveform" Margin="5" HorizontalAlignment="Left" Width="300" SelectionChanged="OnWaveformChanged"/>
        <Grid Name="imageHolder" Grid.Row="1" MouseWheel="OnScroll" SizeChanged="OnResize">
            <Image Name="image" Stretch="Fill"/>
        </Grid>
    </Grid>
</Window>
